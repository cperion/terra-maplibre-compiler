{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Style layer",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["fill", "line", "circle", "background"],
    },
    "source": {
      "type": "string"
    },
    "source-layer": {
      "type": "string"
    },
    "minzoom": {
      "type": "integer",
      "minimum": 0,
      "maximum": 24
    },
    "maxzoom": {
      "type": "integer",
      "minimum": 0,
      "maximum": 24
    },
    "filter": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "paint": {
      "type": "object"
      "additionalProperties": false
    },
    "layout": {
      "type": "object",
      "additionalProperties": false
    }
  },
  "required": ["id", "type", "source", "source-layer"]
}
